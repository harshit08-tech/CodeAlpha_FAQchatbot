st.markdown('<div class="title">FAQ Chatbot</div>', unsafe_allow_html=True)
st.markdown('<div class="subtitle">Ask me anything related to basic AI & programming</div>', unsafe_allow_html=True)

# FAQ Data
questions = [
    "What is AI?",
    "What is machine learning?",
    "What is Python?",
    "What is Streamlit?",
    "Who created you?"
]

answers = [
    "AI is the simulation of human intelligence by machines.",
    "Machine learning is a subset of AI that learns from data.",
    "Python is a popular programming language.",
    "Streamlit is a Python library used to build web apps easily.",
    "I am a chatbot created by Harshit Kabra."
]

# User input
with st.container():
    st.markdown('<div style="text-align: center; margin-bottom: 20px;"><h3>💬 Ask your question</h3></div>', unsafe_allow_html=True)
    user_input = st.text_input("", placeholder="Type your question about AI or programming...").strip()

# Button
if st.button("Ask"):
    if user_input:
        try:
            @st.cache_data
            def get_vectors(input_questions):
                vectorizer = TfidfVectorizer()
                vectors = vectorizer.fit_transform(input_questions)
                return vectors

            all_questions = questions + [user_input]
            vectors = get_vectors(tuple(all_questions))  # tuple for cache key

            similarity = cosine_similarity(vectors[-1], vectors[:-1])
            index = similarity.argmax()
            score = similarity[0][index]

            if score > 0.4:
                st.success(f"🤖 Answer: {answers[index]}")
            else:
                st.warning("❓ Not sure: Sorry, I don't understand the question. Try rephrasing!")
        except Exception as e:
            st.error(f"Error processing question: {str(e)}")
    else:
        st.warning("⚠️ Please enter a question")
